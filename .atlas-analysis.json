  "keyFeatures": [
    "AI Gateway with unified API for 100+ models",
    "LLM observability and request logging",
    "Prompt management and versioning",
    "Session and trace tracking for agents",
    "Cost and latency analytics",
    "Evaluation and scoring framework",
    "Intelligent routing and automatic fallbacks",
    "Custom properties and metadata",
    "Response caching",
    "Rate limiting",
    "Webhooks and alerts",
    "Dataset creation and management",
    "Self-hosting with Docker and Kubernetes"
  ],
  "publicApiSurface": [
    "POST /v1/chat/completions - AI Gateway chat completions endpoint",
    "GET /v1/models - List available AI models",
    "POST /v1/request/query - Query logged requests",
    "GET /v1/request - Get specific request details",
    "POST /v1/request/feedback - Submit request feedback",
    "PUT /v1/request/property - Update request properties",
    "POST /v1/request/score - Score a request",
    "POST /v1/session/query - Query sessions",
    "POST /v1/session/metrics/query - Get session metrics",
    "POST /v1/session/feedback - Submit session feedback",
    "POST /v1/prompt/2025 - Create a prompt",
    "GET /v1/prompt/2025/id/{promptId} - Get prompt by ID",
    "POST /v1/prompt/2025/update - Update prompt version",
    "POST /v1/prompt/2025/query - Query prompts",
    "POST /v1/evals/query - Query evaluations",
    "POST /v1/evals - Create evaluation",
    "GET /v1/evals/scores - Get evaluation scores",
    "GET /v1/webhooks - List webhooks",
    "POST /v1/webhooks - Create webhook",
    "DELETE /v1/webhooks - Delete webhook",
    "POST /v1/user/query - Query users",
    "POST /v1/user/metrics/query - Get user metrics",
    "POST /v1/trace/log - Log trace data",
    "@helicone/async - Async logging SDK with OpenLLMetry",
    "@helicone/prompts - Prompt management SDK"
  ]
